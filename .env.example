# poker44-aquila — required runtime configuration (copy to .env and fill in).
# The miner refuses to start without wallet/hotkey; the manifest goes opaque
# without repo url/name. Commit left blank -> `git rev-parse HEAD` at runtime.
POKER44_WALLET_NAME=
POKER44_WALLET_HOTKEY=
POKER44_NETUID=126
POKER44_AXON_PORT=
POKER44_MODEL_REPO_URL=
POKER44_MODEL_NAME=
POKER44_PM2_NAME=
POKER44_MODEL_REPO_COMMIT=

# optional overrides (defaults live in the code)
POKER44_SUBTENSOR_NETWORK=finney
POKER44_MODEL_VERSION=
POKER44_ARTIFACT=
POKER44_TARGET_FPR=
POKER44_MAX_POS_FRAC=
POKER44_MAX_DEPLOY_FPR=
POKER44_TRAIN_DATA_DIR=
POKER44_TRAIN_JOBS=
POKER44_WF_POINTS=
POKER44_BENCHMARK_REPO_URL=
